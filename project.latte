project(group: "io.github.voidmain", name: "latte-publish-test", version: "0.1.0", licenses: ["MIT"]) {
  workflow {
    standard()
  }
  publishWorkflow {
    latte(apiURL: "http://localhost:8080")
  }

  dependencies {
    group(name: "compile") {
    }
    group(name: "test-compile", export: false) {
      dependency(id: "org.testng:testng:7.10.2")
    }
  }

  publications {
    standard()
  }
}

// Plugins
dependency = loadPlugin(id: "org.lattejava.plugin:dependency:0.3.0")
idea = loadPlugin(id: "org.lattejava.plugin:idea:0.3.0")
java = loadPlugin(id: "org.lattejava.plugin:java:0.3.0")
javaTestNG = loadPlugin(id: "org.lattejava.plugin:java-testng:0.3.0")
release = loadPlugin(id: "org.lattejava.plugin:release-git:0.3.0")

// Plugin settings
java.settings.javaVersion = "25"
javaTestNG.settings.javaVersion = "25"

target(name: "clean", description: "Cleans the project") {
  java.clean()
}

target(name: "build", description: "Compiles and JARs the project") {
  java.compile()
  java.jar()
}

target(name: "test", description: "Runs the project's tests", dependsOn: ["build"]) {
  javaTestNG.test()
}

target(name: "int", description: "Releases a local integration build of the project", dependsOn: ["test"]) {
  dependency.integrate()
}

target(name: "release", description: "Releases a full version of the project", dependsOn: ["clean", "test"]) {
  release.release()
}

target(name: "idea", description: "Updates the IntelliJ IDEA module file") {
  idea.iml()
}

target(name: "print-dependency-tree", description: "Prints the dependency tree") {
  dependency.printFull()
}
